---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const items = await getCollection('guides');
  return items.map((guide) => ({ params: { slug: guide.id }, props: { guide } }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
---

<Base title={`${guide.data.title} — k2gl`} description={guide.data.description}>
  <article>
    <p class="crumb"><a href="/guides">Guides</a></p>
    <h1>{guide.data.title}</h1>
    <div class="body"><Content /></div>
  </article>
  <style>
    .crumb { color: var(--muted); font-size: 0.9rem; }
    .body { margin-top: 1.5rem; }
  </style>
</Base>
