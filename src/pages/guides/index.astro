---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const guides = (await getCollection('guides')).sort((a, b) => a.data.order - b.data.order);
---

<Base title="Guides — k2gl" description="Cross-package how-tos for the k2gl PHP packages.">
  <h1>Guides</h1>
  <ul class="list">
    {guides.map((g) => (
      <li>
        <a href={`/guides/${g.id}`}>{g.data.title}</a>
        <p>{g.data.description}</p>
      </li>
    ))}
  </ul>
  <style>
    .list { list-style: none; padding: 0; display: grid; gap: 1.25rem; }
    .list li a { font-size: 1.1rem; font-weight: 600; text-decoration: none; }
    .list li p { color: var(--muted); margin: 0.2rem 0 0; }
  </style>
</Base>
