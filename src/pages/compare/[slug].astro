---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const items = await getCollection('compare');
  return items.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await render(item);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'QAPage',
  mainEntity: {
    '@type': 'Question',
    name: item.data.title,
    acceptedAnswer: { '@type': 'Answer', text: item.data.description },
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site!.href },
    { '@type': 'ListItem', position: 2, name: 'Comparisons', item: new URL('/compare', Astro.site).href },
    { '@type': 'ListItem', position: 3, name: item.data.title },
  ],
};
---

<Base title={`${item.data.title} — k2gl`} description={item.data.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  </Fragment>
  <article>
    <p class="crumb"><a href="/compare">Comparisons</a></p>
    <h1>{item.data.title}</h1>
    <div class="body"><Content /></div>
  </article>
  <style>
    .crumb { color: var(--muted); font-size: 0.9rem; }
    .body { margin-top: 1.5rem; }
  </style>
</Base>
