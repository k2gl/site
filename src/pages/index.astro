---
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../data/enrichment';
import Base from '../layouts/Base.astro';

const pkgs = (await getCollection('packages')).map((p) => p.data);
const count = (c: string) => pkgs.filter((p) => p.category === c).length;
const flagship = ['sigstore-verify', 'composer-attest']
  .map((s) => pkgs.find((p) => p.slug === s))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));

const site = Astro.site!.href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${site}#website`,
      url: site,
      name: 'k2gl',
      description: 'Supply-chain security & developer utilities for PHP.',
      publisher: { '@id': `${site}#org` },
    },
    {
      '@type': 'Organization',
      '@id': `${site}#org`,
      name: 'k2gl',
      url: site,
      logo: { '@type': 'ImageObject', url: new URL('/apple-touch-icon.png', Astro.site).href },
      sameAs: ['https://github.com/k2gl'],
    },
  ],
};
---

<Base
  title="k2gl — supply-chain security & developer utilities for PHP"
  description="A family of PHP libraries: a conformance-passing pure-PHP Sigstore verifier, Composer plugins that check build provenance at install, and small everyday utilities."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <section class="hero">
    <h1>Software supply-chain security for PHP.</h1>
    <p>
      A pure-PHP <strong>Sigstore</strong> verifier that passes the official conformance suite, the
      attestation formats it builds on (DSSE, in-toto, SLSA, TUF), <strong>Composer plugins</strong>
      that check provenance and licenses at install, and a few general-purpose utilities.
    </p>
    <p><a href="/supply-chain">How it fits together →</a></p>
  </section>

  <section>
    <div class="flagship">
      {flagship.map((p) => (
        <a class="fcard" href={`/packages/${p.slug}`}>
          <strong>{p.name}</strong>
          <span class="tag">{p.tagline}</span>
          <span class="hook">{p.hook}</span>
          <code>{p.install}</code>
        </a>
      ))}
    </div>
  </section>

  <section>
    <h2>By type</h2>
    <div class="cats">
      {CATEGORIES.map((c) => (
        <a class="cat" href="/packages">
          <strong>{c.label} <span class="count">{count(c.key)}</span></strong>
          <span>{c.blurb}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="agents">
    <h2>Machine-readable docs</h2>
    <p>
      Every package has a markdown twin and a <a href="/llms.txt">/llms.txt</a> index, so an AI
      agent can learn to use any of these without reading the source.
    </p>
  </section>

  <style>
    .hero h1 { font-size: 2.1rem; line-height: 1.2; }
    .hero p { font-size: 1.12rem; color: var(--muted); }
    .flagship { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1rem; }
    .fcard {
      display: flex; flex-direction: column; gap: 0.5rem;
      padding: 1.25rem; border: 1px solid var(--border); border-radius: 12px;
      text-decoration: none; color: inherit; transition: border-color 0.15s;
    }
    .fcard:hover { border-color: var(--accent); }
    .fcard strong { color: var(--accent); font-size: 1.15rem; }
    .fcard .tag { color: var(--fg); }
    .fcard .hook { color: var(--muted); font-size: 0.95rem; }
    .fcard code { font-size: 0.82rem; background: var(--code-bg); padding: 0.3em 0.5em; border-radius: 6px; }
    .cats { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 0.85rem; }
    .cat {
      display: flex; flex-direction: column; gap: 0.3rem;
      padding: 0.9rem 1.1rem; border: 1px solid var(--border); border-radius: 10px;
      text-decoration: none; color: inherit;
    }
    .cat:hover { border-color: var(--accent); }
    .cat span { color: var(--muted); font-size: 0.9rem; }
    .count {
      font-size: 0.75rem; color: var(--muted); background: var(--code-bg);
      padding: 0.1em 0.5em; border-radius: 999px;
    }
    .agents { margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border); }
    .agents p { color: var(--muted); }
  </style>
</Base>
