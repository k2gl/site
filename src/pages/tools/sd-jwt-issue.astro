---
import Base from '../../layouts/Base.astro';
import ToolPrivacy from '../../components/ToolPrivacy.astro';
import ToolSwitcher from '../../components/ToolSwitcher.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'SD-JWT generator',
  url: new URL('/tools/sd-jwt-issue', Astro.site).href,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0' },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site!.href },
    { '@type': 'ListItem', position: 2, name: 'Tools', item: new URL('/tools', Astro.site).href },
    { '@type': 'ListItem', position: 3, name: 'SD-JWT generator' },
  ],
};

const phpSnippet = `use K2gl\\SdJwt\\Jws\\JwsSigner;
use K2gl\\SdJwt\\Sd;
use K2gl\\SdJwt\\SdJwtIssuer;

$sdJwt = new SdJwtIssuer(JwsSigner::es256FromPem($issuerPrivatePem))->issue([
    'iss' => 'https://issuer.example.com',
    'sub' => 'user_42',
    'given_name' => Sd::hide('John'),   // selectively disclosable
    'family_name' => Sd::hide('Doe'),
]);

echo $sdJwt->toCompact();`;

const exampleClaims = `{
  "iss": "https://issuer.example.com",
  "sub": "user_42",
  "given_name": "John",
  "family_name": "Doe",
  "email": "john@example.com"
}`;
---

<Base
  title="SD-JWT generator — issue a test token online"
  description="Build a demo SD-JWT (RFC 9901): choose which claims are selectively disclosable, get the compact token plus the throwaway issuer keys — ready to paste into the debugger."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  </Fragment>

  <article>
    <ToolSwitcher current="sd-jwt-issue" />
    <h1>SD-JWT generator</h1>
    <p class="lead">
      Issue a demo <a href="https://www.rfc-editor.org/rfc/rfc9901">RFC 9901</a> SD-JWT: your
      claims, your choice of what's selectively disclosable, signed with a fresh throwaway ES256
      key. Then take it apart in the <a href="/tools/sd-jwt">debugger</a>.
    </p>
    <ToolPrivacy />

    <form id="tool-form">
      <label>
        Claims (JSON object)
        <textarea name="claims" rows="8" required spellcheck="false">{exampleClaims}</textarea>
      </label>
      <label>
        Selectively disclosable claims (comma-separated names)
        <input type="text" name="disclose" spellcheck="false" value="given_name, family_name, email" />
      </label>
      <button type="submit">Issue</button>
    </form>

    <section id="out" hidden>
      <h2>Result <span id="badge"></span></h2>
      <div id="result"></div>
    </section>

    <section class="explain">
      <h2>What you get</h2>
      <p>
        The claims you mark disclosable leave the signed payload — only their salted digests stay
        in <code>_sd</code>; the values travel as separate disclosures after the <code>~</code>
        separators. The response includes the issuer's public key (PEM and JWK) so you can verify
        the token — in the <a href="/tools/sd-jwt">SD-JWT debugger</a> or in code — and the private
        key so nothing about the demo is hidden. The keys are generated per request and never stored;
        don't reuse them for anything real.
      </p>

      <h2>Do it in PHP</h2>
      <pre><code class="language-php">{phpSnippet}</code></pre>
      <p>
        Powered by <a href="/packages/sd-jwt">k2gl/sd-jwt</a>; for issuing verifiable credentials
        (<code>dc+sd-jwt</code>) on top, see <a href="/packages/sd-jwt-vc">k2gl/sd-jwt-vc</a>.
      </p>
    </section>
  </article>

  <style>
    .lead { color: var(--muted); font-size: 1.05rem; }
    form { display: grid; gap: 1rem; margin: 1.5rem 0; }
    label { display: grid; gap: 0.35rem; font-weight: 600; font-size: 0.92rem; }
    textarea, input[type='text'] {
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.85rem;
      width: 100%; padding: 0.6rem; border: 1px solid var(--border); border-radius: 8px;
      background: var(--code-bg); color: var(--fg); resize: vertical;
    }
    button {
      justify-self: start; padding: 0.5em 1.4em; border: none; border-radius: 8px;
      background: var(--accent); color: #fff; font-size: 1rem; cursor: pointer;
    }
    button:disabled { opacity: 0.6; cursor: wait; }
    #badge { font-size: 0.7em; padding: 0.25em 0.7em; border-radius: 999px; vertical-align: middle; }
    #badge.ok { background: #2f9e44; color: #fff; }
    #badge.fail { background: #d6336c; color: #fff; }
    #result h3 { margin: 1.4rem 0 0.5rem; font-size: 1.02rem; }
    #result pre {
      background: var(--code-bg); padding: 1rem; border-radius: 8px;
      overflow-x: auto; white-space: pre-wrap; word-break: break-all;
    }
    #result .warn { color: var(--muted); font-size: 0.9rem; }
    .err { color: #d6336c; }
    .explain { margin-top: 2.5rem; border-top: 1px solid var(--border); padding-top: 1.5rem; }
  </style>

  <script is:inline>
    (() => {
      const form = document.getElementById('tool-form');
      const out = document.getElementById('out');
      const badge = document.getElementById('badge');
      const result = document.getElementById('result');

      const el = (tag, text, cls) => {
        const node = document.createElement(tag);
        if (text !== undefined && text !== null) node.textContent = text;
        if (cls) node.className = cls;
        return node;
      };
      const section = (title, text) => {
        result.append(el('h3', title));
        const pre = el('pre');
        pre.append(el('code', text));
        result.append(pre);
      };

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const button = form.querySelector('button');
        button.disabled = true;
        out.hidden = false;
        result.replaceChildren(el('p', 'Issuing…'));

        let claims;
        try { claims = JSON.parse(form.claims.value); }
        catch { badge.className = 'fail'; badge.textContent = 'error'; result.replaceChildren(el('p', 'Claims are not valid JSON.', 'err')); button.disabled = false; return; }

        const disclose = form.disclose.value.split(',').map((s) => s.trim()).filter(Boolean);

        try {
          const res = await fetch('/api/v1/sd-jwt/issue', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ claims, disclose }),
          });
          const data = await res.json();
          if (!data.ok) {
            badge.className = 'fail';
            badge.textContent = 'error';
            result.replaceChildren(el('p', data.error.message + ' (' + data.error.code + ')', 'err'));
          } else {
            const r = data.result;
            badge.textContent = 'issued (' + r.disclosures + ' disclosures)';
            badge.className = 'ok';
            result.replaceChildren();
            section('SD-JWT (compact)', r.sdJwt);
            const link = el('p');
            link.append('Inspect it: copy the token into the ');
            const a = el('a', 'SD-JWT debugger');
            a.href = '/tools/sd-jwt';
            link.append(a, ' along with the public key below.');
            result.append(link);
            section('Issuer public key (PEM)', r.issuerKey.publicPem.trim());
            section('Issuer public key (JWK)', JSON.stringify(r.issuerKey.publicJwk));
            section('Issuer private key (PEM — throwaway)', r.issuerKey.privatePem.trim());
            result.append(el('p', r.note, 'warn'));
          }
        } catch {
          badge.className = 'fail';
          badge.textContent = 'error';
          result.replaceChildren(el('p', 'The tools API is unreachable — try again shortly.', 'err'));
        } finally {
          button.disabled = false;
        }
      });
    })();
  </script>
</Base>
