---
import Base from '../../layouts/Base.astro';
import ToolPrivacy from '../../components/ToolPrivacy.astro';
import ToolSwitcher from '../../components/ToolSwitcher.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Composer attestation checker',
  url: new URL('/tools/composer-attestations', Astro.site).href,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0' },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site!.href },
    { '@type': 'ListItem', position: 2, name: 'Tools', item: new URL('/tools', Astro.site).href },
    { '@type': 'ListItem', position: 3, name: 'Composer attestation checker' },
  ],
};
---

<Base
  title="Composer attestation checker — does a Packagist package ship build provenance?"
  description="Enter any vendor/package name to check whether its releases publish GitHub build-provenance attestations, verified against the Sigstore trust root."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  </Fragment>

  <article>
    <ToolSwitcher current="composer-attestations" />
    <h1>Composer attestation checker</h1>
    <p class="lead">
      Does a Packagist package publish verifiable build provenance? This resolves the release,
      downloads its dist zip, hashes it and verifies GitHub's attestations for that exact digest —
      the same check <a href="/packages/composer-attest">k2gl/composer-attest</a> runs at install time.
    </p>
    <ToolPrivacy />

    <form id="tool-form">
      <label>
        Package
        <input type="text" name="package" required spellcheck="false" placeholder="vendor/package" />
      </label>
      <label>
        Version (optional — defaults to the newest stable release)
        <input type="text" name="version" spellcheck="false" placeholder="1.2.3" />
      </label>
      <button type="submit">Check</button>
    </form>

    <section id="out" hidden>
      <h2>Result <span id="badge"></span></h2>
      <div id="result"></div>
    </section>

    <section class="explain">
      <h2>What a verified result means</h2>
      <p>
        <strong>verified</strong> — GitHub holds a build-provenance attestation whose subject digest
        equals the zip Composer would install, signed by a GitHub Actions workflow of the package's
        own repository and logged in the Rekor transparency log. You know <em>which workflow, from
        which commit</em>, produced the artifact. <strong>no attestation</strong> — the release
        simply doesn't publish provenance (that's still the norm on Packagist).
        <strong>failed</strong> — an attestation exists but doesn't verify; treat that seriously.
      </p>
      <p>
        Checks run against the release dist zip (capped at 64&nbsp;MiB) and are cached for
        15&nbsp;minutes.
      </p>

      <h2>Check it at install time instead</h2>
      <pre><code class="language-bash">composer require --dev k2gl/composer-attest</code></pre>
      <p>
        The plugin performs this verification for every package on every install/update, and
        <code>composer attest</code> audits an existing lock file. See
        <a href="/packages/composer-attest">k2gl/composer-attest</a> and the
        <a href="/guides/verify-provenance-at-install">install-time verification guide</a> — and
        <a href="/guides/attest-your-package">attest your own package</a> so this page says
        <em>verified</em> about you.
      </p>
    </section>
  </article>

  <style>
    .crumb { color: var(--muted); font-size: 0.9rem; }
    .lead { color: var(--muted); font-size: 1.05rem; }
    form { display: grid; gap: 1rem; margin: 1.5rem 0; max-width: 28rem; }
    label { display: grid; gap: 0.35rem; font-weight: 600; font-size: 0.92rem; }
    input[type='text'] {
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.9rem;
      width: 100%; padding: 0.55rem; border: 1px solid var(--border); border-radius: 8px;
      background: var(--code-bg); color: var(--fg);
    }
    button {
      justify-self: start; padding: 0.5em 1.4em; border: none; border-radius: 8px;
      background: var(--accent); color: #fff; font-size: 1rem; cursor: pointer;
    }
    button:disabled { opacity: 0.6; cursor: wait; }
    #badge { font-size: 0.7em; padding: 0.25em 0.7em; border-radius: 999px; vertical-align: middle; }
    #badge.ok { background: #2f9e44; color: #fff; }
    #badge.fail { background: #d6336c; color: #fff; }
    #badge.skip { background: var(--code-bg); color: var(--muted); }
    #result dl { display: grid; grid-template-columns: max-content 1fr; gap: 0.3rem 1rem; }
    #result dt { font-weight: 600; color: var(--muted); }
    #result dd { margin: 0; overflow-wrap: anywhere; }
    .err { color: #d6336c; }
    .explain { margin-top: 2.5rem; border-top: 1px solid var(--border); padding-top: 1.5rem; }
  </style>

  <script is:inline>
    (() => {
      const form = document.getElementById('tool-form');
      const out = document.getElementById('out');
      const badge = document.getElementById('badge');
      const result = document.getElementById('result');

      const el = (tag, text, cls) => {
        const node = document.createElement(tag);
        if (text !== undefined && text !== null) node.textContent = text;
        if (cls) node.className = cls;
        return node;
      };
      const row = (dl, term, value) => {
        if (value === undefined || value === null || value === '') return;
        dl.append(el('dt', term), el('dd', value));
      };

      const badges = {
        verified: ['provenance verified', 'ok'],
        no_attestation: ['no attestation published', 'skip'],
        unsupported_host: ['not a GitHub release', 'skip'],
        failed: ['attestation FAILED to verify', 'fail'],
      };

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const button = form.querySelector('button');
        button.disabled = true;
        out.hidden = false;
        result.replaceChildren(el('p', 'Checking — downloading and hashing the release zip may take a few seconds…'));

        const params = new URLSearchParams({ package: form.package.value.trim() });
        if (form.version.value.trim()) params.set('version', form.version.value.trim());

        try {
          const res = await fetch('/api/v1/composer/attestations?' + params.toString());
          const data = await res.json();
          if (!data.ok) {
            badge.className = 'fail';
            badge.textContent = 'error';
            result.replaceChildren(el('p', data.error.message + ' (' + data.error.code + ')', 'err'));
          } else {
            const r = data.result;
            const [label, cls] = badges[r.attestation.status] || [r.attestation.status, 'skip'];
            badge.textContent = label;
            badge.className = cls;

            const dl = el('dl');
            row(dl, 'package', r.package + ' ' + r.version);
            if (r.source) row(dl, 'repository', 'github.com/' + r.source.owner + '/' + r.source.repo);
            if (r.dist) row(dl, 'dist sha256', r.dist.sha256);
            row(dl, 'verdict', r.attestation.status + (r.attestation.identity ? ' — ' + r.attestation.identity : ''));
            row(dl, 'detail', r.attestation.message);
            if (r.provenance) {
              row(dl, 'signing identity', r.provenance.identity);
              row(dl, 'workflow ref', r.provenance.workflowRef);
              row(dl, 'commit', r.provenance.commit);
              row(dl, 'predicate', r.provenance.predicateType);
              row(dl, 'builder', r.provenance.builderId);
            }
            if (r.cached) row(dl, 'freshness', 'cached (≤15 min)');
            result.replaceChildren(dl);
          }
        } catch {
          badge.className = 'fail';
          badge.textContent = 'error';
          result.replaceChildren(el('p', 'The tools API is unreachable — try again shortly.', 'err'));
        } finally {
          button.disabled = false;
        }
      });
    })();
  </script>
</Base>
