---
import Base from '../../layouts/Base.astro';
import ToolPrivacy from '../../components/ToolPrivacy.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'SD-JWT debugger',
  url: new URL('/tools/sd-jwt', Astro.site).href,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0' },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site!.href },
    { '@type': 'ListItem', position: 2, name: 'Tools', item: new URL('/tools', Astro.site).href },
    { '@type': 'ListItem', position: 3, name: 'SD-JWT debugger' },
  ],
};

const phpSnippet = `use K2gl\\Dsse\\PublicKey;
use K2gl\\SdJwt\\SdJwtVerifier;

// Verifies the issuer signature and every disclosure digest (RFC 9901),
// then hands back the recreated claims.
$claims = new SdJwtVerifier()
    ->verify($compactSdJwt, PublicKey::fromJwk($issuerJwk))
    ->claims();`;
---

<Base
  title="SD-JWT debugger — decode & verify SD-JWT and SD-JWT VC online"
  description="Paste an SD-JWT (RFC 9901) or SD-JWT VC to decode its disclosures, recompute digests, rebuild the disclosed claims and verify the issuer signature."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  </Fragment>

  <article>
    <p class="crumb"><a href="/tools">Tools</a></p>
    <h1>SD-JWT debugger</h1>
    <p class="lead">
      Decode a Selective Disclosure JWT (<a href="https://www.rfc-editor.org/rfc/rfc9901">RFC 9901</a>)
      or an SD-JWT VC: every disclosure, its recomputed digest, the recreated claim set and the
      key-binding JWT — optionally verifying the issuer signature.
    </p>
    <ToolPrivacy />

    <form id="tool-form">
      <label>
        SD-JWT (compact form, <code>~</code>-separated)
        <textarea name="sdJwt" rows="8" required spellcheck="false"
          placeholder="eyJhbGciOiAiRVMyNTYi...~WyJfMjZiYzRiotZi...~eyJhbGciOiAiRVMyNTYi..."></textarea>
      </label>
      <details>
        <summary>Issuer public key (optional — enables signature verification)</summary>
        <label>
          JWK (JSON)
          <textarea name="issuerKeyJwk" rows="4" spellcheck="false" placeholder='&#123;"kty":"EC","crv":"P-256","x":"...","y":"..."&#125;'></textarea>
        </label>
        <label>
          or PEM (SPKI)
          <textarea name="issuerKeyPem" rows="4" spellcheck="false" placeholder="-----BEGIN PUBLIC KEY-----"></textarea>
        </label>
      </details>
      <button type="submit">Inspect</button>
    </form>

    <section id="out" hidden>
      <h2>Result <span id="badge"></span></h2>
      <div id="result"></div>
    </section>

    <section class="explain">
      <h2>How SD-JWT selective disclosure works</h2>
      <p>
        The issuer never signs your claims in the clear: each selectively disclosable claim is
        replaced by the digest of a <em>disclosure</em> — <code>[salt, name, value]</code>, encoded
        and hashed. The signed payload carries only digests (<code>_sd</code> arrays and
        <code>...</code> array markers); the holder chooses which disclosures to hand over.
        A verifier recomputes each digest and only accepts disclosures whose digest is actually
        referenced by the signed payload — that's what the <em>referenced</em> flag shows here.
      </p>
      <p>
        For presentations, the key-binding JWT proves the holder controls the key the credential
        was issued to. This tool decodes the KB-JWT but doesn't check it — a real verification
        needs your expected audience and nonce.
      </p>

      <h2>Do it in PHP</h2>
      <pre><code class="language-php">{phpSnippet}</code></pre>
      <p>
        Powered by <a href="/packages/sd-jwt">k2gl/sd-jwt</a>; for
        <code>dc+sd-jwt</code> verifiable credentials (vct, issuer metadata, status), see
        <a href="/packages/sd-jwt-vc">k2gl/sd-jwt-vc</a>.
      </p>
    </section>
  </article>

  <style>
    .crumb { color: var(--muted); font-size: 0.9rem; }
    .lead { color: var(--muted); font-size: 1.05rem; }
    form { display: grid; gap: 1rem; margin: 1.5rem 0; }
    label { display: grid; gap: 0.35rem; font-weight: 600; font-size: 0.92rem; }
    textarea {
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.85rem;
      width: 100%; padding: 0.6rem; border: 1px solid var(--border); border-radius: 8px;
      background: var(--code-bg); color: var(--fg); resize: vertical;
    }
    details { border: 1px solid var(--border); border-radius: 8px; padding: 0.6rem 0.9rem; }
    details[open] { display: grid; gap: 1rem; }
    summary { cursor: pointer; color: var(--muted); font-size: 0.92rem; }
    button {
      justify-self: start; padding: 0.5em 1.4em; border: none; border-radius: 8px;
      background: var(--accent); color: #fff; font-size: 1rem; cursor: pointer;
    }
    button:disabled { opacity: 0.6; cursor: wait; }
    #badge { font-size: 0.7em; padding: 0.25em 0.7em; border-radius: 999px; vertical-align: middle; }
    #badge.ok { background: #2f9e44; color: #fff; }
    #badge.fail { background: #d6336c; color: #fff; }
    #badge.skip { background: var(--code-bg); color: var(--muted); }
    #result h3 { margin: 1.4rem 0 0.5rem; font-size: 1.02rem; }
    #result dl { display: grid; grid-template-columns: max-content 1fr; gap: 0.3rem 1rem; }
    #result dt { font-weight: 600; color: var(--muted); }
    #result dd { margin: 0; overflow-wrap: anywhere; }
    #result pre { max-height: 22rem; overflow: auto; }
    #result table { font-size: 0.88rem; border-collapse: collapse; width: 100%; }
    #result .no { color: #d6336c; font-weight: 600; }
    .err { color: #d6336c; }
    .explain { margin-top: 2.5rem; border-top: 1px solid var(--border); padding-top: 1.5rem; }
  </style>

  <script is:inline>
    (() => {
      const form = document.getElementById('tool-form');
      const out = document.getElementById('out');
      const badge = document.getElementById('badge');
      const result = document.getElementById('result');

      const el = (tag, text, cls) => {
        const node = document.createElement(tag);
        if (text !== undefined && text !== null) node.textContent = text;
        if (cls) node.className = cls;
        return node;
      };
      const row = (dl, term, value) => {
        if (value === undefined || value === null || value === '') return;
        dl.append(el('dt', term), typeof value === 'string' ? el('dd', value) : value);
      };
      const jsonPre = (value) => {
        const dd = el('dd');
        const p = el('pre');
        p.append(el('code', JSON.stringify(value, null, 2)));
        dd.append(p);
        return dd;
      };
      const section = (title) => {
        result.append(el('h3', title));
        const dl = el('dl');
        result.append(dl);
        return dl;
      };

      const setBadge = (verification) => {
        if (!verification || !verification.attempted) {
          badge.textContent = 'decoded';
          badge.className = 'skip';
        } else if (verification.verified) {
          badge.textContent = 'issuer signature verified';
          badge.className = 'ok';
        } else {
          badge.textContent = 'verification failed';
          badge.className = 'fail';
        }
      };

      const render = (r) => {
        result.replaceChildren();

        const tdl = section('Token');
        row(tdl, 'profile', r.profile === 'vc' ? 'SD-JWT VC' : 'SD-JWT');
        row(tdl, 'typ', r.header && r.header.typ);
        row(tdl, 'alg', r.header && r.header.alg);
        row(tdl, 'hash algorithm', r.sdAlg);
        if (r.verification && r.verification.reason) row(tdl, 'note', r.verification.reason);
        if (r.verification && r.verification.vc) {
          row(tdl, 'vct', r.verification.vc.vct);
          row(tdl, 'issuer', r.verification.vc.issuer);
        }

        result.append(el('h3', 'Disclosures (' + r.disclosures.length + ')'));
        const table = el('table');
        const head = el('tr');
        ['claim', 'value', 'digest', 'referenced'].forEach((h) => head.append(el('th', h)));
        table.append(head);
        r.disclosures.forEach((d) => {
          const tr = el('tr');
          tr.append(el('td', d.kind === 'arrayElement' ? '(array element)' : d.claimName));
          tr.append(el('td', JSON.stringify(d.value)));
          tr.append(el('td', d.digest || '—'));
          tr.append(d.referenced ? el('td', 'yes') : el('td', 'NO — stray disclosure', 'no'));
          table.append(tr);
        });
        result.append(table);

        const cdl = section('Recreated claims (as a verifier would see them)');
        row(cdl, 'claims', jsonPre(r.recreatedClaims));

        const kdl = section('Key binding');
        if (!r.keyBinding.present) {
          row(kdl, 'present', 'no — issuance form');
        } else {
          row(kdl, 'present', 'yes (decoded, not checked — needs your aud + nonce)');
          if (r.keyBinding.payload) row(kdl, 'payload', jsonPre(r.keyBinding.payload));
        }

        const pdl = section('Signed payload (digests intact)');
        row(pdl, 'payload', jsonPre(r.payload));
      };

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const button = form.querySelector('button');
        button.disabled = true;
        out.hidden = false;
        result.replaceChildren(el('p', 'Inspecting…'));

        const body = { sdJwt: form.sdJwt.value.trim() };
        if (form.issuerKeyJwk.value.trim()) {
          try { body.issuerKeyJwk = JSON.parse(form.issuerKeyJwk.value); }
          catch { badge.className = 'fail'; badge.textContent = 'error'; result.replaceChildren(el('p', 'The JWK is not valid JSON.', 'err')); button.disabled = false; return; }
        } else if (form.issuerKeyPem.value.trim()) body.issuerKeyPem = form.issuerKeyPem.value;

        try {
          const res = await fetch('/api/v1/sd-jwt/inspect', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify(body),
          });
          const data = await res.json();
          if (!data.ok) {
            badge.className = 'fail';
            badge.textContent = 'error';
            result.replaceChildren(el('p', data.error.message + ' (' + data.error.code + ')', 'err'));
          } else {
            setBadge(data.result.verification);
            render(data.result);
          }
        } catch {
          badge.className = 'fail';
          badge.textContent = 'error';
          result.replaceChildren(el('p', 'The tools API is unreachable — try again shortly.', 'err'));
        } finally {
          button.disabled = false;
        }
      });
    })();
  </script>
</Base>
