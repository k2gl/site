---
import Base from '../../layouts/Base.astro';
import ToolPrivacy from '../../components/ToolPrivacy.astro';
import ToolSwitcher from '../../components/ToolSwitcher.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'SSH signature verifier',
  url: new URL('/tools/sshsig', Astro.site).href,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0' },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site!.href },
    { '@type': 'ListItem', position: 2, name: 'Tools', item: new URL('/tools', Astro.site).href },
    { '@type': 'ListItem', position: 3, name: 'SSH signature verifier' },
  ],
};

const phpSnippet = `use K2gl\\Sshsig\\AllowedSigners;
use K2gl\\Sshsig\\SshsigVerifier;

// The ssh-keygen -Y verify semantics: signature, principal, namespace,
// validity window — throws unless everything checks out.
$verified = new SshsigVerifier()->verify(
    message: $message,
    armoredSignature: $armored,
    allowedSigners: AllowedSigners::fromFile('allowed_signers'),
    identity: 'alice@example.com',
    namespace: 'file',
);`;
---

<Base
  title="SSH signature verifier — check SSHSIG online"
  description="Paste a message and its SSHSIG block to verify it like ssh-keygen -Y verify: signature, allowed_signers identity, namespace — with the parsed key and algorithms shown."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  </Fragment>

  <article>
    <ToolSwitcher current="sshsig" />
    <h1>SSH signature verifier</h1>
    <p class="lead">
      Verify an <a href="https://github.com/openssh/openssh-portable/blob/master/PROTOCOL.sshsig">SSHSIG</a>
      signature — the format behind <code>ssh-keygen -Y sign</code> and SSH-signed git commits —
      against the message it covers, and optionally against an <code>allowed_signers</code> identity.
    </p>
    <ToolPrivacy />

    <form id="tool-form">
      <label>
        Message (the signed data, verbatim)
        <textarea name="message" rows="4" required spellcheck="false" placeholder="exactly the bytes that were signed"></textarea>
      </label>
      <label>
        Signature (armored SSHSIG block)
        <textarea name="signature" rows="6" required spellcheck="false" placeholder="-----BEGIN SSH SIGNATURE-----"></textarea>
      </label>
      <details>
        <summary>allowed_signers (optional — ties the key to an identity, like ssh-keygen -Y verify)</summary>
        <label>
          allowed_signers content
          <textarea name="allowedSigners" rows="3" spellcheck="false" placeholder="alice@example.com ssh-ed25519 AAAA..."></textarea>
        </label>
        <label>
          Expected identity (principal)
          <input type="text" name="identity" spellcheck="false" placeholder="alice@example.com" />
        </label>
        <label>
          Namespace (defaults to the one inside the signature)
          <input type="text" name="namespace" spellcheck="false" placeholder="file" />
        </label>
      </details>
      <button type="submit">Verify</button>
    </form>

    <section id="out" hidden>
      <h2>Result <span id="badge"></span></h2>
      <div id="result"></div>
    </section>

    <section class="explain">
      <h2>Two modes, like OpenSSH's own</h2>
      <p>
        Without an <code>allowed_signers</code> list this runs
        <code>ssh-keygen -Y check-novalidate</code> semantics: the signature is checked against the
        message and the embedded public key — proof of integrity, but nothing ties that key to a
        person. Supply the list and an expected identity to get full
        <code>ssh-keygen -Y verify</code> semantics: principal match, namespace match and the
        key's validity window.
      </p>

      <h2>Do it in PHP</h2>
      <pre><code class="language-php">{phpSnippet}</code></pre>
      <p>
        Powered by <a href="/packages/sshsig">k2gl/sshsig</a> — Ed25519, ECDSA and RSA, byte-compatible
        with OpenSSH.
      </p>
    </section>
  </article>

  <style>
    .lead { color: var(--muted); font-size: 1.05rem; }
    form { display: grid; gap: 1rem; margin: 1.5rem 0; }
    label { display: grid; gap: 0.35rem; font-weight: 600; font-size: 0.92rem; }
    textarea, input[type='text'] {
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.85rem;
      width: 100%; padding: 0.6rem; border: 1px solid var(--border); border-radius: 8px;
      background: var(--code-bg); color: var(--fg); resize: vertical;
    }
    details { border: 1px solid var(--border); border-radius: 8px; padding: 0.6rem 0.9rem; }
    details[open] { display: grid; gap: 1rem; }
    summary { cursor: pointer; color: var(--muted); font-size: 0.92rem; }
    button {
      justify-self: start; padding: 0.5em 1.4em; border: none; border-radius: 8px;
      background: var(--accent); color: #fff; font-size: 1rem; cursor: pointer;
    }
    button:disabled { opacity: 0.6; cursor: wait; }
    #badge { font-size: 0.7em; padding: 0.25em 0.7em; border-radius: 999px; vertical-align: middle; }
    #badge.ok { background: #2f9e44; color: #fff; }
    #badge.fail { background: #d6336c; color: #fff; }
    #badge.skip { background: var(--code-bg); color: var(--muted); }
    #result dl { display: grid; grid-template-columns: max-content 1fr; gap: 0.3rem 1rem; }
    #result dt { font-weight: 600; color: var(--muted); }
    #result dd { margin: 0; overflow-wrap: anywhere; }
    .err { color: #d6336c; }
    .explain { margin-top: 2.5rem; border-top: 1px solid var(--border); padding-top: 1.5rem; }
  </style>

  <script is:inline>
    (() => {
      const form = document.getElementById('tool-form');
      const out = document.getElementById('out');
      const badge = document.getElementById('badge');
      const result = document.getElementById('result');

      const el = (tag, text, cls) => {
        const node = document.createElement(tag);
        if (text !== undefined && text !== null) node.textContent = text;
        if (cls) node.className = cls;
        return node;
      };
      const row = (dl, term, value) => {
        if (value === undefined || value === null || value === '') return;
        dl.append(el('dt', term), el('dd', value));
      };

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const button = form.querySelector('button');
        button.disabled = true;
        out.hidden = false;
        result.replaceChildren(el('p', 'Verifying…'));

        const body = { message: form.message.value, signature: form.signature.value };
        if (form.allowedSigners.value.trim()) body.allowedSigners = form.allowedSigners.value;
        if (form.identity.value.trim()) body.identity = form.identity.value.trim();
        if (form.namespace.value.trim()) body.namespace = form.namespace.value.trim();

        try {
          const res = await fetch('/api/v1/sshsig/verify', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify(body),
          });
          const data = await res.json();
          if (!data.ok) {
            badge.className = 'fail';
            badge.textContent = 'error';
            result.replaceChildren(el('p', data.error.message + ' (' + data.error.code + ')', 'err'));
          } else {
            const r = data.result;
            const v = r.verification;
            if (!v.attempted) { badge.textContent = 'parsed'; badge.className = 'skip'; }
            else if (v.verified) { badge.textContent = v.mode === 'allowed-signers' ? 'verified' : 'signature valid'; badge.className = 'ok'; }
            else { badge.textContent = 'verification failed'; badge.className = 'fail'; }

            const dl = el('dl');
            row(dl, 'namespace', r.signature.namespace);
            row(dl, 'signature algorithm', r.signature.signatureAlgorithm);
            row(dl, 'hash algorithm', r.signature.hashAlgorithm);
            row(dl, 'key fingerprint', r.signature.publicKeyFingerprint);
            row(dl, 'mode', v.mode);
            row(dl, 'identity', v.identity);
            row(dl, 'principals', v.principals);
            row(dl, 'note', v.note || v.reason);
            result.replaceChildren(dl);
          }
        } catch {
          badge.className = 'fail';
          badge.textContent = 'error';
          result.replaceChildren(el('p', 'The tools API is unreachable — try again shortly.', 'err'));
        } finally {
          button.disabled = false;
        }
      });
    })();
  </script>
</Base>
