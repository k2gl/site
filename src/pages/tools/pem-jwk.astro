---
import Base from '../../layouts/Base.astro';
import ToolSwitcher from '../../components/ToolSwitcher.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'PEM ⇄ JWK converter',
  url: new URL('/tools/pem-jwk', Astro.site).href,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0' },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site!.href },
    { '@type': 'ListItem', position: 2, name: 'Tools', item: new URL('/tools', Astro.site).href },
    { '@type': 'ListItem', position: 3, name: 'PEM ⇄ JWK converter' },
  ],
};

const phpSnippet = `use K2gl\\Dsse\\PublicKey;

// The k2gl packages accept either form directly — often you don't need
// to convert at all:
$verifier = PublicKey::fromPem($pem);
$verifier = PublicKey::fromJwk($jwk);`;
---

<Base
  title="PEM ⇄ JWK converter — in your browser, keys never leave the tab"
  description="Convert RSA, EC (P-256/384/521) and Ed25519 keys between PEM (SPKI/PKCS#8) and JWK — entirely client-side via WebCrypto, so private keys are never uploaded."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  </Fragment>

  <article>
    <ToolSwitcher current="pem-jwk" />
    <h1>PEM ⇄ JWK converter</h1>
    <p class="lead">
      Paste a key in either format — the direction is detected automatically. RSA, EC
      (P-256/P-384/P-521) and Ed25519; public and private keys.
    </p>
    <p class="tool-privacy">
      This tool is deliberately different from the others: it runs <strong>entirely in your
      browser</strong> (WebCrypto). Keys — including private ones — are never sent anywhere.
    </p>

    <form id="tool-form">
      <label>
        Key (PEM or JWK)
        <textarea name="input" rows="9" required spellcheck="false" placeholder='-----BEGIN PUBLIC KEY-----  …or…  &#123;"kty":"EC","crv":"P-256",...&#125;'></textarea>
      </label>
      <button type="submit">Convert</button>
    </form>

    <section id="out" hidden>
      <h2>Result <span id="badge"></span></h2>
      <div id="result"></div>
    </section>

    <section class="explain">
      <h2>Supported forms</h2>
      <p>
        PEM input must be <code>PUBLIC KEY</code> (SPKI) or <code>PRIVATE KEY</code> (PKCS#8) —
        the modern OpenSSL defaults. Legacy <code>RSA PRIVATE KEY</code> / <code>EC PRIVATE
        KEY</code> / <code>OPENSSH PRIVATE KEY</code> blocks aren't importable by WebCrypto;
        re-wrap them first with
        <code>openssl pkey -in old.pem -out pkcs8.pem</code>.
      </p>

      <h2>Often you don't need this at all</h2>
      <pre><code class="language-php">{phpSnippet}</code></pre>
      <p>
        <a href="/packages/dsse">k2gl/dsse</a> (and everything built on it — SD-JWT verification
        included) takes PEM and JWK interchangeably.
      </p>
    </section>
  </article>

  <style>
    .lead { color: var(--muted); font-size: 1.05rem; }
    .tool-privacy { color: var(--muted); font-size: 0.88rem; border-left: 3px solid var(--border); padding-left: 0.75rem; }
    form { display: grid; gap: 1rem; margin: 1.5rem 0; }
    label { display: grid; gap: 0.35rem; font-weight: 600; font-size: 0.92rem; }
    textarea {
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.85rem;
      width: 100%; padding: 0.6rem; border: 1px solid var(--border); border-radius: 8px;
      background: var(--code-bg); color: var(--fg); resize: vertical;
    }
    button {
      justify-self: start; padding: 0.5em 1.4em; border: none; border-radius: 8px;
      background: var(--accent); color: #fff; font-size: 1rem; cursor: pointer;
    }
    #badge { font-size: 0.7em; padding: 0.25em 0.7em; border-radius: 999px; vertical-align: middle; }
    #badge.ok { background: #2f9e44; color: #fff; }
    #badge.fail { background: #d6336c; color: #fff; }
    #result pre {
      background: var(--code-bg); padding: 1rem; border-radius: 8px;
      overflow-x: auto; white-space: pre-wrap; word-break: break-all;
    }
    .err { color: #d6336c; }
    .explain { margin-top: 2.5rem; border-top: 1px solid var(--border); padding-top: 1.5rem; }
  </style>

  <script is:inline>
    (() => {
      const form = document.getElementById('tool-form');
      const out = document.getElementById('out');
      const badge = document.getElementById('badge');
      const result = document.getElementById('result');

      const el = (tag, text, cls) => {
        const node = document.createElement(tag);
        if (text !== undefined && text !== null) node.textContent = text;
        if (cls) node.className = cls;
        return node;
      };
      const show = (label, text) => {
        result.replaceChildren(el('p', label));
        const pre = el('pre');
        pre.append(el('code', text));
        result.append(pre);
      };
      const fail = (message) => {
        badge.textContent = 'error';
        badge.className = 'fail';
        result.replaceChildren(el('p', message, 'err'));
      };

      const b64ToBuf = (b64) => Uint8Array.from(atob(b64), (c) => c.charCodeAt(0)).buffer;
      const bufToB64 = (buf) => btoa(String.fromCharCode(...new Uint8Array(buf)));
      const armor = (label, buf) => {
        const b64 = bufToB64(buf).replace(/(.{64})/g, '$1\n').trim();
        return `-----BEGIN ${label}-----\n${b64}\n-----END ${label}-----`;
      };

      // Import candidates: the DER doesn't say how the key will be used, so try
      // algorithms from most to least specific until one fits.
      const CANDIDATES = [
        { alg: { name: 'Ed25519' }, sign: ['sign'], verify: ['verify'], label: 'Ed25519' },
        { alg: { name: 'ECDSA', namedCurve: 'P-256' }, sign: ['sign'], verify: ['verify'], label: 'EC P-256' },
        { alg: { name: 'ECDSA', namedCurve: 'P-384' }, sign: ['sign'], verify: ['verify'], label: 'EC P-384' },
        { alg: { name: 'ECDSA', namedCurve: 'P-521' }, sign: ['sign'], verify: ['verify'], label: 'EC P-521' },
        { alg: { name: 'RSASSA-PKCS1-v1_5', hash: 'SHA-256' }, sign: ['sign'], verify: ['verify'], label: 'RSA' },
        { alg: { name: 'RSA-OAEP', hash: 'SHA-256' }, sign: ['decrypt'], verify: ['encrypt'], label: 'RSA (OAEP)' },
      ];

      const pemToJwk = async (pem, match) => {
        const label = match[1];
        if (label !== 'PUBLIC KEY' && label !== 'PRIVATE KEY') {
          throw new Error(`"${label}" blocks are not importable by WebCrypto — re-wrap as PKCS#8/SPKI first (see note below).`);
        }
        const isPrivate = label === 'PRIVATE KEY';
        const der = b64ToBuf(match[2].replace(/\s+/g, ''));
        for (const c of CANDIDATES) {
          try {
            const key = await crypto.subtle.importKey(isPrivate ? 'pkcs8' : 'spki', der, c.alg, true, isPrivate ? c.sign : c.verify);
            const jwk = await crypto.subtle.exportKey('jwk', key);
            delete jwk.key_ops; delete jwk.ext; delete jwk.alg;
            return { text: JSON.stringify(jwk, null, 2), label: c.label + (isPrivate ? ' private' : ' public') + ' key → JWK' };
          } catch { /* try the next algorithm */ }
        }
        throw new Error('No supported algorithm matched (RSA, EC P-256/384/521, Ed25519).');
      };

      const jwkToPem = async (jwk) => {
        let alg;
        if (jwk.kty === 'EC') alg = { name: 'ECDSA', namedCurve: jwk.crv };
        else if (jwk.kty === 'OKP' && jwk.crv === 'Ed25519') alg = { name: 'Ed25519' };
        else if (jwk.kty === 'RSA') alg = { name: 'RSASSA-PKCS1-v1_5', hash: 'SHA-256' };
        else throw new Error('Unsupported JWK (kty ' + jwk.kty + ') — RSA, EC and OKP/Ed25519 are supported.');

        const isPrivate = 'd' in jwk;
        const key = await crypto.subtle.importKey('jwk', jwk, alg, true, isPrivate ? ['sign'] : ['verify']);
        const der = await crypto.subtle.exportKey(isPrivate ? 'pkcs8' : 'spki', key);
        return {
          text: armor(isPrivate ? 'PRIVATE KEY' : 'PUBLIC KEY', der),
          label: (alg.namedCurve || alg.name) + (isPrivate ? ' private' : ' public') + ' key → PEM',
        };
      };

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        out.hidden = false;
        const input = form.input.value.trim();
        const pemMatch = input.match(/-----BEGIN ([A-Z0-9 ]+)-----([\s\S]+?)-----END \1-----/);

        try {
          let converted;
          if (pemMatch) converted = await pemToJwk(input, pemMatch);
          else {
            let jwk;
            try { jwk = JSON.parse(input); } catch { throw new Error('Input is neither a PEM block nor valid JWK JSON.'); }
            converted = await jwkToPem(jwk);
          }
          badge.textContent = 'converted';
          badge.className = 'ok';
          show(converted.label, converted.text);
        } catch (err) {
          fail(err.message || String(err));
        }
      });
    })();
  </script>
</Base>
