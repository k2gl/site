---
import { getCollection } from 'astro:content';
import { marked } from 'marked';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const pkgs = await getCollection('packages');
  return pkgs.map((p) => ({ params: { name: p.data.slug }, props: { pkg: p.data } }));
}

const { pkg } = Astro.props;
const readmeHtml = await marked.parse(pkg.readme);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareSourceCode',
  name: pkg.name,
  description: pkg.tagline,
  codeRepository: pkg.links.github,
  programmingLanguage: 'PHP',
  license: 'https://opensource.org/licenses/MIT',
  author: { '@type': 'Person', name: 'Nick Harin' },
};
---

<Base title={`${pkg.name} — ${pkg.tagline}`} description={pkg.tagline}>
  <Fragment slot="head">
    <link rel="alternate" type="text/markdown" href={`/packages/${pkg.slug}.md`} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <article>
    <p class="crumb"><a href="/packages">Packages</a> · {pkg.family}</p>
    <h1>{pkg.name}</h1>
    <p class="tagline">{pkg.tagline}</p>
    {pkg.hook && <p class="hook">{pkg.hook}</p>}

    <p class="badges">
      <a href={pkg.links.packagist}>
        <img src={`https://img.shields.io/packagist/v/${pkg.name}?label=Packagist`} alt={`${pkg.name} version on Packagist`} height="20" loading="lazy" />
      </a>
      <img src={`https://img.shields.io/packagist/dt/${pkg.name}?label=downloads`} alt={`${pkg.name} total downloads`} height="20" loading="lazy" />
      <img src={`https://img.shields.io/packagist/l/${pkg.name}?label=license`} alt={`${pkg.name} license`} height="20" loading="lazy" />
    </p>

    <h2>Install</h2>
    <pre><code>{pkg.install}</code></pre>

    <dl class="meta">
      {pkg.php && (<><dt>PHP</dt><dd>{pkg.php}</dd></>)}
      {pkg.requires.length > 0 && (
        <>
          <dt>k2gl dependencies</dt>
          <dd>
            {pkg.requires.map((r, i) => (
              <>
                {i > 0 ? ', ' : ''}
                <a href={`/packages/${r.name.replace('k2gl/', '')}`}>{r.name}</a>
              </>
            ))}
          </dd>
        </>
      )}
    </dl>

    <div class="readme" set:html={readmeHtml} />

    {pkg.api.length > 0 && (
      <section class="api">
        <h2>API</h2>
        <p class="api-note">Public classes and methods, generated from the source.</p>
        {pkg.api.map((cls) => (
          <div class="cls">
            <h3><code>{cls.name}</code> <span class="kind">{cls.kind}</span></h3>
            {cls.methods.length > 0 && (
              <ul>{cls.methods.map((m) => <li><code>{m}</code></li>)}</ul>
            )}
          </div>
        ))}
      </section>
    )}

    <footer class="links">
      <a href={pkg.links.github}>GitHub</a> ·
      <a href={pkg.links.packagist}>Packagist</a> ·
      <a href={`/packages/${pkg.slug}.md`}>Markdown (for agents)</a>
    </footer>
  </article>

  <style>
    .crumb { color: var(--muted); font-size: 0.9rem; }
    h1 { margin-bottom: 0.25rem; }
    .tagline { font-size: 1.25rem; color: var(--muted); margin-top: 0; }
    .hook { font-size: 1.05rem; }
    .badges { display: flex; gap: 0.4rem; flex-wrap: wrap; align-items: center; margin: 0.5rem 0 1.25rem; }
    .badges img { height: 20px; display: block; }
    .meta { display: grid; grid-template-columns: max-content 1fr; gap: 0.25rem 1rem; }
    .meta dt { font-weight: 600; color: var(--muted); }
    .meta dd { margin: 0; }
    .readme { margin-top: 2rem; border-top: 1px solid var(--border); padding-top: 1.5rem; }
    .links { margin-top: 2rem; color: var(--muted); }
    .api { margin-top: 2rem; border-top: 1px solid var(--border); padding-top: 1.5rem; }
    .api-note { color: var(--muted); font-size: 0.9rem; margin-top: 0; }
    .cls { margin: 1.5rem 0; }
    .cls h3 { margin-bottom: 0.4rem; word-break: break-word; }
    .kind { font-size: 0.72rem; color: var(--muted); background: var(--code-bg); padding: 0.12em 0.55em; border-radius: 999px; vertical-align: middle; }
    .api ul { list-style: none; padding-left: 0; display: grid; gap: 0.35rem; }
    .api li code { font-size: 0.85rem; }
  </style>
</Base>
