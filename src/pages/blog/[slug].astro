---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={`${post.data.title} — k2gl`} description={post.data.description}>
  <article>
    <p class="crumb"><a href="/blog">Blog</a></p>
    <h1>{post.data.title}</h1>
    <time datetime={post.data.date.toISOString()}>{post.data.date.toISOString().slice(0, 10)}</time>
    <div class="body"><Content /></div>
  </article>

  <style>
    .crumb { color: var(--muted); font-size: 0.9rem; }
    h1 { margin-bottom: 0.15rem; }
    time { color: var(--muted); font-size: 0.9rem; }
    .body { margin-top: 1.5rem; }
  </style>
</Base>
