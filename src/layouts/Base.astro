---
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
}

const { title, description, canonical, ogType = 'website', ogImage = '/og.png' } = Astro.props;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const ogImageURL = new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // Apply the saved theme before paint to avoid a flash.
      (() => { try { const t = localStorage.getItem('theme'); if (t) document.documentElement.dataset.theme = t; } catch {} })();
    </script>
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:site_name" content="k2gl" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="k2gl — supply-chain security & developer utilities for PHP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#ffffff" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#14141f" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="alternate" type="application/rss+xml" title="k2gl blog" href="/rss.xml" />
    <link rel="stylesheet" href="/hljs/github.min.css" media="(prefers-color-scheme: light)" />
    <link rel="stylesheet" href="/hljs/github-dark.min.css" media="(prefers-color-scheme: dark)" />
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand">k2gl</a>
      <nav>
        <a href="/start">Start</a>
        <a href="/packages">Packages</a>
        <a href="/guides">Guides</a>
        <a href="/blog">Blog</a>
        <a href="/search">Search</a>
        <a href="https://github.com/k2gl">GitHub</a>
        <button class="theme-toggle" type="button" aria-label="Toggle light/dark theme" title="Toggle theme">◐</button>
      </nav>
    </header>
    <main class="site-main">
      <slot />
    </main>
    <footer class="site-footer">
      <p>Open-source PHP packages by Nick Harin · MIT · <a href="/llms.txt">llms.txt</a></p>
    </footer>
    <style is:global>
      :root {
        --fg: #1a1a2e;
        --muted: #55566a;
        --bg: #ffffff;
        --accent: #3b5bdb;
        --border: #e4e4ef;
        --code-bg: #f5f5fa;
        --maxw: 52rem;
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --fg: #e6e6f0;
          --muted: #9a9ab0;
          --bg: #14141f;
          --accent: #7a90ff;
          --border: #2a2a3d;
          --code-bg: #1e1e2d;
        }
      }
      /* Explicit choice via the toggle wins over the OS preference. */
      :root[data-theme="light"] {
        --fg: #1a1a2e; --muted: #55566a; --bg: #ffffff;
        --accent: #3b5bdb; --border: #e4e4ef; --code-bg: #f5f5fa;
      }
      :root[data-theme="dark"] {
        --fg: #e6e6f0; --muted: #9a9ab0; --bg: #14141f;
        --accent: #7a90ff; --border: #2a2a3d; --code-bg: #1e1e2d;
      }
      .theme-toggle {
        background: none; border: 1px solid var(--border); border-radius: 6px;
        color: var(--muted); cursor: pointer; font-size: 0.9rem;
        padding: 0.1em 0.5em; line-height: 1.4;
      }
      .theme-toggle:hover { color: var(--accent); border-color: var(--accent); }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        color: var(--fg);
        background: var(--bg);
        line-height: 1.65;
      }
      a { color: var(--accent); }
      .site-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--border);
        flex-wrap: wrap;
      }
      .brand { font-weight: 700; font-size: 1.2rem; text-decoration: none; }
      .site-header nav { display: flex; gap: 1.25rem; }
      .site-header nav a { text-decoration: none; color: var(--muted); }
      .site-header nav a:hover { color: var(--accent); }
      .site-main { max-width: var(--maxw); margin: 0 auto; padding: 2rem 1.5rem; }
      .site-footer {
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 2rem 1.5rem;
        color: var(--muted);
        border-top: 1px solid var(--border);
        font-size: 0.9rem;
      }
      pre {
        background: var(--code-bg);
        padding: 1rem;
        border-radius: 8px;
        overflow-x: auto;
        position: relative;
      }
      .copy-btn {
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
        font-size: 0.72rem;
        padding: 0.2em 0.6em;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: var(--bg);
        color: var(--muted);
        cursor: pointer;
        opacity: 0;
        transition: opacity 0.15s;
      }
      pre:hover .copy-btn { opacity: 1; }
      .copy-btn:hover { color: var(--accent); border-color: var(--accent); }
      code { background: var(--code-bg); padding: 0.15em 0.4em; border-radius: 4px; }
      pre code { background: none; padding: 0; }
      h1, h2, h3 { line-height: 1.25; }
      table { border-collapse: collapse; width: 100%; }
      th, td { border: 1px solid var(--border); padding: 0.4rem 0.6rem; text-align: left; }
    </style>
    <script is:inline src="/hljs/highlight.min.js"></script>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        if (window.hljs) window.hljs.highlightAll();
      });
    </script>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        for (const pre of document.querySelectorAll('pre')) {
          const codeText = pre.innerText; // capture before appending the button
          const btn = document.createElement('button');
          btn.className = 'copy-btn';
          btn.type = 'button';
          btn.textContent = 'Copy';
          btn.addEventListener('click', async () => {
            try {
              await navigator.clipboard.writeText(codeText);
              btn.textContent = 'Copied';
              setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
            } catch {
              btn.textContent = 'Failed';
            }
          });
          pre.appendChild(btn);
        }
      });
    </script>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        // Once a theme is chosen explicitly, the media-query theme-color metas no
        // longer match reality — pin both to the chosen theme's color.
        const syncThemeColor = (theme) => {
          const color = theme === 'dark' ? '#14141f' : '#ffffff';
          for (const m of document.querySelectorAll('meta[name="theme-color"]')) m.setAttribute('content', color);
        };
        if (document.documentElement.dataset.theme) syncThemeColor(document.documentElement.dataset.theme);
        const btn = document.querySelector('.theme-toggle');
        if (!btn) return;
        btn.addEventListener('click', () => {
          const root = document.documentElement;
          const current = root.dataset.theme
            || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          const next = current === 'dark' ? 'light' : 'dark';
          root.dataset.theme = next;
          syncThemeColor(next);
          try { localStorage.setItem('theme', next); } catch {}
        });
      });
    </script>
  </body>
</html>
