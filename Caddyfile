{$SITE_DOMAIN:k2gl.com} {
	encode zstd gzip

	# Access logs feed GoAccess (the goaccess service in deploy/docker-compose.yml
	# reads this file from a shared volume). JSON so GoAccess parses it as CADDY.
	log {
		output file /var/log/caddy/access.log {
			roll_size 10MiB
			roll_keep 20
			roll_keep_for 2160h # ~90 days of history
		}
		format json
	}

	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Frame-Options "DENY"
		Cross-Origin-Opener-Policy "same-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=(), interest-cohort=()"
		-Server
	}

	# Private GoAccess dashboard — basic auth, never indexed. The default hash is a
	# throwaway lock (bcrypt of a random string, plaintext discarded): if STATS_USER
	# / STATS_HASH aren't set in .env the endpoint is just unreachable and Caddy still
	# starts, so the site never goes down. Real credentials come from the environment.
	handle_path /_stats* {
		basic_auth {
			{$STATS_USER:k2gl} {$STATS_HASH:$2a$14$YewCzl48OP2I67jFNNDfx.YpVgZ4cvZ8lXfJtyYIjh8SwcGuLFdoy}
		}
		header X-Robots-Tag "noindex"
		log_skip
		root * /report
		file_server
	}

	# The tools API — a FrankenPHP container on the compose network. Bodies are
	# capped here so oversized payloads die at the edge.
	handle /api/* {
		request_body {
			max_size 1MB
		}
		reverse_proxy api:8080
	}

	# First-party Umami tracker: only the script and its beacon are exposed — the
	# dashboard and login live on the (basic-auth'd) stats host below.
	handle /u/script.js {
		rewrite * /script.js
		reverse_proxy umami:3000
	}
	handle /u/api/send {
		rewrite * /api/send
		log_skip
		reverse_proxy umami:3000
	}

	# Everything else: the static site.
	handle {
		root * /srv

		# A deliberately loose CSP. The site is static with no user input, so a strict
		# source allowlist is mostly ceremony — and it breaks legitimate off-site assets
		# (Packagist badges from img.shields.io). Keep only the free, non-fragile wins —
		# no plugins, no framing, no base-tag or off-site form hijack — and don't restrict
		# where assets load from.
		header Content-Security-Policy "object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'"

		# Machine endpoints must never be indexed (near-duplicates of the HTML).
		# Char-class [.] avoids Caddyfile backslash-escaping surprises.
		@machine path_regexp "[.](md|json)$"
		header @machine X-Robots-Tag "noindex"
		@llms path /llms.txt /llms-full.txt
		header @llms X-Robots-Tag "noindex"

		# Fingerprinted assets are immutable; everything else revalidates so content
		# (and the agent-facing endpoints) never goes stale.
		@assets path /_astro/*
		header @assets Cache-Control "public, max-age=31536000, immutable"
		@dynamic not path /_astro/*
		header @dynamic Cache-Control "public, max-age=0, must-revalidate"

		# Clean URLs: /packages/sigstore-verify -> sigstore-verify.html (no redirect).
		try_files {path} {path}.html {path}/index.html
		file_server
	}

	# Serve the branded 404 page on misses (Astro emits dist/404.html); the error
	# status code is preserved.
	handle_errors {
		@404 expression `{err.status_code} == 404`
		handle @404 {
			root * /srv
			rewrite * /404.html
			file_server
		}
	}
}

# The Umami dashboard. Off by default: STATS_DOMAIN's .localhost fallback keeps
# Caddy on an internal cert (no ACME attempts) until the real subdomain has a DNS
# record and .env sets it. Basic auth mirrors /_stats — same throwaway default.
{$STATS_DOMAIN:stats.localhost} {
	header X-Robots-Tag "noindex"

	# Browsers fetch the web manifest WITHOUT credentials (spec), so a 401 here
	# traps Chrome in an endless auth prompt. The manifest is harmless — serve it.
	handle /site.webmanifest {
		reverse_proxy umami:3000
	}

	handle {
		basic_auth {
			{$STATS_USER:k2gl} {$STATS_HASH:$2a$14$YewCzl48OP2I67jFNNDfx.YpVgZ4cvZ8lXfJtyYIjh8SwcGuLFdoy}
		}
		reverse_proxy umami:3000
	}
}
