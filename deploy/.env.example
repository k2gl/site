# Copy to .env on the VPS next to docker-compose.yml.
# The site domain Caddy issues a TLS certificate for.
SITE_DOMAIN=k2gl.com
# Image tag to run (latest, or a specific sha-<gitsha> for pinning/rollback).
SITE_TAG=latest
# Basic-auth for the private GoAccess dashboard at /_stats. Leave unset to keep it
# locked. Generate the hash with:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'YOUR_PASSWORD'
# IMPORTANT: in this file, double every '$' in the bcrypt hash -> '$$', otherwise
# docker-compose eats it as variable interpolation.
STATS_USER=admin
STATS_HASH=
