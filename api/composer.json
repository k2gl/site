{
    "name": "k2gl/site-api",
    "description": "Server-side engine for the k2gl.com online tools — runs the k2gl packages themselves.",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Nick Harin"
        }
    ],
    "require": {
        "php": ">=8.4",
        "ext-json": "*",
        "ext-openssl": "*",
        "ext-sodium": "*",
        "k2gl/composer-attest": "^1.1",
        "k2gl/dsse": "^1.3",
        "k2gl/in-toto-attestation": "^1.2",
        "k2gl/sd-jwt": "^1.0",
        "k2gl/sd-jwt-vc": "^1.0",
        "k2gl/sigstore-verify": "^1.4",
        "k2gl/slsa-provenance": "^1.2"
    },
    "require-dev": {
        "k2gl/phpunit-fluent-assertions": "^12.10",
        "phpunit/phpunit": "^12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "k2gl/composer-attest": false
        },
        "sort-packages": true
    }
}
